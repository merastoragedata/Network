="1" parent="1" source="PARLYPG" target="KALAMBPG"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="5601" y="4486"/><mxPoint x="3921" y="4486"/></Array></mxGeometry></mxCell><mxCell id="L89_name" value="Parli PG - Kalamb PG Ckt 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#37474F;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L89"><mxGeometry x="0.55" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="L90" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0288D1;strokeWidth=2;fontSize=8;fontColor=#455A64;labelBackgroundColor=#FFFFFF;startArrow=block;startFill=1;endArrow=none;exitX=0.793;exitY=1;exitDx=0;exitDy=0;entryX=0.720;entryY=0;entryDx=0;entryDy=0;jettySize=12;" edge="1" parent="1" source="PADGHAPG" target="CHDPR"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1074" y="2070"/><mxPoint x="6650" y="2070"/></Array></mxGeometry></mxCell><mxCell id="L90_name" value="Chandrapur - Padgha PG HVDC Pole 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#37474F;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L90"><mxGeometry x="-0.55" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="L91" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0288D1;strokeWidth=2;fontSize=8;fontColor=#455A64;labelBackgroundColor=#FFFFFF;startArrow=block;startFill=1;endArrow=none;exitX=0.940;exitY=1;exitDx=0;exitDy=0;entryX=0.940;entryY=0;entryDx=0;entryDy=0;jettySize=12;" edge="1" parent="1" source="PADGHAPG" target="CHDPR"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1121" y="2090"/><mxPoint x="6721" y="2090"/></Array></mxGeometry></mxCell><mxCell id="L91_name" value="Chandrapur - Padgha PG HVDC Pole 2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#37474F;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L91"><mxGeometry x="-0.28" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="legend" value="&lt;b&gt;MSETCL 765 / 400 kV NETWORK — WORKING TEMPLATE&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Buses&lt;/b&gt; magenta 765 kV, red 400 kV. Dashed bus = off-page connector (same station drawn twice on the SLDC sheet).&lt;br&gt;&lt;b&gt;Symbols above each bus&lt;/b&gt; — left: AC/DC box = HVDC converter. Centre: twin circles = ICT (magenta 765/400, amber 400/220), one pair per transformer. Right: circle with ~ = generation (orange thermal, blue hydro, green gas, purple nuclear).&lt;br&gt;&lt;b&gt;Circuits&lt;/b&gt; leave the bottom of a bus, each on its own tap and its own horizontal lane, so no two circuits overlap. Arrow shows normal flow direction.&lt;br&gt;&lt;br&gt;&lt;b&gt;Names&lt;/b&gt; every bus and every circuit has an editable label. Double-click to rename. Circuits are named From - To Ckt n.&lt;br&gt;&lt;br&gt;&lt;b&gt;Editing&lt;/b&gt; 1. Move buses and re-route circuits to match the SLDC sheet. 2. Delete a wrong circuit; draw a new connector between two buses to add one; a second connector between the same pair becomes Ckt 2. 3. Avoid deleting a bus — move it instead, so it keeps its ID. 4. Save as .drawio and upload in Settings &gt; draw.io round-trip." style="text;html=1;fontSize=12;align=left;verticalAlign=top;fontColor=#37474F;labelBackgroundColor=#FFF8E1;msetclDecor=1;" vertex="1" parent="1"><mxGeometry x="260" y="5026" width="1180" height="240" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>