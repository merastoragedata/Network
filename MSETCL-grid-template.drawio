e=28;jumpStyle=arc;jumpSize=18;orthogonalLoop=1;elbow=vertical;" edge="1" parent="1" source="DHULEBD" target="PUNEGIS"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="L113_name" value="Dhule BD - Pune GIS Ckt 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=25;fontColor=#C62828;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L113"><mxGeometry x="0.28" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="L114" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D32F2F;strokeWidth=5;fontSize=8;fontColor=#455A64;labelBackgroundColor=#FFFFFF;startArrow=block;startFill=1;endArrow=none;exitX=0.500;exitY=1;exitDx=0;exitDy=0;entryX=0.600;entryY=0;entryDx=0;entryDy=0;jettySize=28;jumpStyle=arc;jumpSize=18;orthogonalLoop=1;elbow=vertical;" edge="1" parent="1" source="VDODRAPG" target="DHULEBD"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="L114_name" value="Dhule BD - Vadodara PG Ckt 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=25;fontColor=#C62828;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L114"><mxGeometry x="0.55" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="L115" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D32F2F;strokeWidth=5;fontSize=8;fontColor=#455A64;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;startArrow=none;exitX=0.550;exitY=1;exitDx=0;exitDy=0;entryX=0.450;entryY=0;entryDx=0;entryDy=0;jettySize=28;jumpStyle=arc;jumpSize=18;orthogonalLoop=1;elbow=vertical;" edge="1" parent="1" source="CHDPR2" target="NANDED"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="L115_name" value="Chandrapur-2 - Nanded Ckt 1" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=25;fontColor=#C62828;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L115"><mxGeometry x="-0.55" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="L116" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#D32F2F;strokeWidth=5;fontSize=8;fontColor=#455A64;labelBackgroundColor=#FFFFFF;endArrow=block;endFill=1;startArrow=none;exitX=0.550;exitY=1;exitDx=0;exitDy=0;entryX=0.400;entryY=1;entryDx=0;entryDy=0;jettySize=28;jumpStyle=arc;jumpSize=18;orthogonalLoop=1;elbow=vertical;" edge="1" parent="1" source="DHRWL" target="CHDPRSW"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="L116_name" value="Dharwal - Chandrapur SW Ckt 2" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=25;fontColor=#37474F;labelBackgroundColor=#FFFFFF;msetclLineName=1;" vertex="1" connectable="0" parent="L116"><mxGeometry x="-0.28" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry></mxCell><mxCell id="legend" value="&lt;b&gt;MSETCL 765 / 400 kV NETWORK — WORKING TEMPLATE&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Buses&lt;/b&gt; magenta 765 kV, red 400 kV. Dashed bus = off-page connector (same station drawn twice on the SLDC sheet).&lt;br&gt;&lt;b&gt;Symbols above each bus&lt;/b&gt; — left: AC/DC box = HVDC converter. Centre: twin circles = ICT (magenta 765/400, amber 400/220), one pair per transformer. Right: circle with ~ = generation (orange thermal, blue hydro, green gas, purple nuclear).&lt;br&gt;&lt;b&gt;Circuits&lt;/b&gt; leave the bottom of a bus, each on its own tap and its own horizontal lane, so no two circuits overlap. Arrow shows normal flow direction.&lt;br&gt;&lt;br&gt;&lt;b&gt;Crossings&lt;/b&gt; where two circuits cross they are drawn with a hop (arc) so a crossing can never be mistaken for a connection. Long circuits descend through the corridor beside their target column to keep clear of other buses.&lt;br&gt;&lt;br&gt;&lt;b&gt;Names&lt;/b&gt; every bus and every circuit has an editable label. Double-click to rename. Circuits are named From - To Ckt n.&lt;br&gt;&lt;br&gt;&lt;b&gt;Editing&lt;/b&gt; 1. Move buses and re-route circuits to match the SLDC sheet. 2. Delete a wrong circuit; draw a new connector between two buses to add one; a second connector between the same pair becomes Ckt 2. 3. Avoid deleting a bus — move it instead, so it keeps its ID. 4. Save as .drawio and upload in Settings &gt; draw.io round-trip." style="text;html=1;fontSize=22;align=left;verticalAlign=top;fontColor=#37474F;labelBackgroundColor=#FFF8E1;msetclDecor=1;" vertex="1" parent="1"><mxGeometry x="416" y="10686" width="2300" height="470" as="geometry"/></mxCell><mxCell id="checklist" value="&lt;b&gt;REVIEW CHECKLIST — please verify against the SLDC sheet&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;A. Stations with only one circuit&lt;/b&gt; (marked with a red ? on the drawing). A 400 kV station almost always has two or more. Missing circuits are most likely here:&lt;br&gt;&amp;nbsp;&amp;nbsp;• 400 kV Nandra&lt;br&gt;&lt;br&gt;&lt;b&gt;B. Corridors drawn as a single circuit&lt;/b&gt; — 91 of 104. Circuit names shown in RED are single-circuit corridors. Most EHV corridors are double circuit, so many of these probably need a Ckt 2 adding. Draw a second connector between the same pair to add one." style="text;html=1;fontSize=22;align=left;verticalAlign=top;fontColor=#B71C1C;labelBackgroundColor=#FFEBEE;msetclDecor=1;" vertex="1" parent="1"><mxGeometry x="2916" y="10686" width="2100" height="500" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>